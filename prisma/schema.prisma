generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//
// 👤 Base User (common record for both roles)
//
model User {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  username   String
  email      String     @unique
  password   String
  role       String      // "hawker" or "customer"
  phone      String?
  address    String?
  isApproved Boolean     @default(false)
  createdAt  DateTime    @default(now())

  // Relations (optional, no fields/references here)
  hawker     Hawker?
  customer   Customer?
  image     String? 
}

//
// 🧺 Hawker Model
//
model Hawker {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  userId     String     @unique
  user       User       @relation(fields: [userId], references: [id])
  products   Product[]
  isApproved Boolean     @default(false)
  createdAt  DateTime    @default(now())
  chats Chat[]
  feedbacks    Feedback[]
}

//
// 🛍️ Customer Model
//
model Customer {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  userId     String     @unique
  user       User       @relation(fields: [userId], references: [id])
  isApproved Boolean     @default(false)
  createdAt  DateTime    @default(now())
  chats Chat[]
  feedbacks    Feedback[]
}

//
// 📦 Product Model
//
model Product {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  description String?
  price       String
  hawkerId  String?
  hawker    Hawker? @relation(fields: [hawkerId], references: [id])
  createdAt DateTime   @default(now())
    carts     Cart[]

}
model Chat {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  customer  Customer @relation(fields: [customerId], references: [id])
  customerId String
  hawker    Hawker   @relation(fields: [hawkerId], references: [id])
  hawkerId  String
  messages  Message[]
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  chat      Chat     @relation(fields: [chatId], references: [id])
  chatId    String
  senderRole String  // "customer" or "hawker"
  text      String
  createdAt DateTime @default(now())
}
model Cart {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  productId  String   @db.ObjectId
  quantity   Int      @default(1)

  product    Product  @relation(fields: [productId], references: [id])

  order      Order?   @relation("OrderItems", fields: [orderId], references: [id])
  orderId    String?  @db.ObjectId

  createdAt  DateTime @default(now())
}

model Order {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId  String   @db.ObjectId
  hawkerId    String   @db.ObjectId
  products    Cart[]   @relation("OrderItems") 
  totalAmount Float
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}
model Feedback {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  rating      Int
  comment     String
  createdAt   DateTime @default(now())

  // Relation with Customer
  customerId  String   @db.ObjectId
  customer    Customer @relation(fields: [customerId], references: [id])

  // Relation with Hawker
  hawkerId    String   @db.ObjectId
  hawker      Hawker   @relation(fields: [hawkerId], references: [id])
}

